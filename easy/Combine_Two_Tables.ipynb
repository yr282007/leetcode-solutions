   "source": [
    "import pandas as pd\n",
    "\n",
    "def combine_two_tables(person: pd.DataFrame, address: pd.DataFrame) -> pd.DataFrame:\n",
    "    df=pd.merge(person,address,on=\"personId\",how=\"left\")\n",
    "    df2=df[['firstName','lastName','city','state']]\n",
    "    return df2"
   ]
