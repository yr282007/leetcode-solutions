   "source": [
    "class Solution:\n",
    "    def twoSum(self, nums, target):\n",
    "        self.nums=nums\n",
    "        self.target=target\n",
    "        for i in range(len(nums)):\n",
    "            for j in range(i+1,len(nums)):\n",
    "                if nums[i]+nums[j] ==target:\n",
    "                    return i,j\n"
   ]
